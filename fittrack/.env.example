# USDA FoodData Central API key (required for Macros food search).
# Get a free key at https://fdc.nal.usda.gov/api-key-signup.html
# Copy this file to .env and fill in your key. DEMO_KEY works for light testing.
VITE_USDA_API_KEY=

# ExerciseDB (exercise demo popup). The hosted v1 API is free and needs NO key.
# Uses GET /api/v1/exercises?name=... (NOT /search, which is often unavailable).
# Leave both blank to use the default https://oss.exercisedb.dev/api/v1 host.
VITE_EXERCISEDB_BASE=
VITE_EXERCISEDB_KEY=

# Backend API base URL (exercise demo proxy, lift coach). Defaults to http://localhost:3000.
VITE_API_BASE_URL=
